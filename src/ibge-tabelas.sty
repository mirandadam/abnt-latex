% =============================================================================
% ibge-tabular.sty
% Normas de Apresentação Tabular — IBGE, 3ª ed., 1993
%
% Licença: LPPL 1.3c
% Versão:  0.1.0 (esboço de arquitetura)
%
% Dependências:
%   tabularray  — estrutura e estilo das tabelas         (expl3-nativo)
%   siunitx     — alinhamento numérico e unidades        (expl3-nativo)
%   caption     — formatação do título no topo
%   xparse      — interface de comandos (já incluso no LaTeX moderno)
%   expl3       — lógica programática interna
% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesExplPackage{ibge-tabular}{2024/01/01}{0.1.0}
  {Normas de Apresentação Tabular — IBGE 1993}

% -----------------------------------------------------------------------------
% 1. DEPENDÊNCIAS
% -----------------------------------------------------------------------------
% tabularray é o núcleo. Ele permite separar completamente a definição de
% estrutura (colunas, linhas) da definição de estilo (traços, cores, fontes).
% Isso mapeia diretamente para a distinção que a norma faz entre "moldura"
% (traços) e "conteúdo" (dados, cabeçalho, indicadores).
\RequirePackage{tabularray}
\RequirePackage{siunitx}
\RequirePackage{caption}
\RequirePackage{xparse}

% -----------------------------------------------------------------------------
% 2. CONFIGURAÇÃO DO siunitx PARA O PADRÃO BRASILEIRO
%    (seções 4.6, 4.7 — vírgula decimal, separador de milhar por espaço)
% -----------------------------------------------------------------------------
\sisetup{
  output-decimal-marker  = {,},   % vírgula decimal (padrão brasileiro)
  group-separator        = {\,},  % espaço fino como separador de milhar
  group-minimum-digits   = 4,     % ex.: 1 000 (e não 1000 vs 10 000)
}

% -----------------------------------------------------------------------------
% 3. DEFINIÇÃO DO AMBIENTE CENTRAL: tabelaibge
%    Baseado em tabularray, com as restrições estruturais da norma embutidas.
%
%    Seção 4.3.1: mínimo três traços horizontais paralelos
%    Seção 4.3.3: a moldura NÃO deve ter traços verticais nas bordas
% -----------------------------------------------------------------------------
\NewTblrEnviron{tabelaibge}

\SetTblrInner[tabelaibge]{
  % --- Moldura (seção 4.3) ---
  % Três traços horizontais obrigatórios:
  %   hline{1}  = traço que separa o topo do centro
  %   hline{2}  = traço que separa o espaço do cabeçalho dos dados
  %   hline{Z}  = traço que separa o centro do rodapé
  % Traços verticais nas bordas PROIBIDOS (seção 4.3.3):
  %   vline nos extremos = nunca
  hlines         = {},              % ponto de partida: nenhum traço
  vlines         = {},              % sem traços verticais (padrão)
  % Os três traços horizontais obrigatórios são definidos pelo usuário
  % via \ibgeSetLinhas (ver seção 5 abaixo), mas o ambiente já define
  % os traços de abertura e fechamento como padrão:
  hline{1}       = {0.8pt, solid}, % traço superior (início do centro)
  hline{2}       = {0.4pt, solid}, % traço do cabeçalho
  hline{Z}       = {0.8pt, solid}, % traço inferior (início do rodapé)
  % --- Alinhamento padrão de células ---
  % Colunas indicadoras: alinhamento à esquerda
  % Colunas numéricas:   alinhamento à direita (sobrescrito pelo siunitx)
  column{1}      = {l},
  column{2-Z}    = {r},
  % --- Espaçamento interno ---
  rowsep         = 2pt,
  colsep         = 6pt,
}

% -----------------------------------------------------------------------------
% 4. SINAIS CONVENCIONAIS (seção 4.8.1)
%    Comandos semânticos que encapsulam cada sinal, de forma que:
%    a) o significado fica no código, não no PDF
%    b) é fácil mudar a representação tipográfica depois
%
%    a) dado igual a zero não resultante de arredondamento  → traço (—)
%    b) não se aplica dado numérico                         → dois pontos (..)
%    c) dado numérico não disponível                        → reticências (...)
%    d) dado omitido (individualização)                     → x
%    e) zero resultante de arredondamento positivo          → 0 / 0,0 / 0,00
%    f) zero resultante de arredondamento negativo          → −0 / −0,0 / −0,00
% -----------------------------------------------------------------------------

% Sinal (a): zero real, não de arredondamento
\NewDocumentCommand{\ibgeSinalZero}{}{\textemdash}

% Sinal (b): não aplicável
\NewDocumentCommand{\ibgeSinalNA}{}{..}

% Sinal (c): dado indisponível
\NewDocumentCommand{\ibgeSinalND}{}{...}

% Sinal (d): dado omitido para evitar individualização
\NewDocumentCommand{\ibgeSinalOmitido}{}{\textit{x}}

% Sinais (e) e (f): zeros de arredondamento
% O argumento opcional define o número de casas decimais (padrão: 0)
% O argumento estrela indica valor originalmente negativo
\NewDocumentCommand{\ibgeSinalArrZero}{ s O{0} }{
  \IfBooleanTF{#1}
    { \ibge_sinal_arr_neg:n {#2} }
    { \ibge_sinal_arr_pos:n {#2} }
}

% Implementação interna em expl3
\cs_new:Npn \ibge_sinal_arr_pos:n #1 {
  \int_compare:nNnTF {#1} = {0}
    { 0 }
    { 0 \text{,} \prg_replicate:nn {#1} {0} }
}

\cs_new:Npn \ibge_sinal_arr_neg:n #1 {
  \int_compare:nNnTF {#1} = {0}
    { $-$0 }
    { $-$0 \text{,} \prg_replicate:nn {#1} {0} }
}

% -----------------------------------------------------------------------------
% 5. ESTRUTURA DO RODAPÉ (seções 4.10, 4.11, 4.12)
%    A norma define uma ordem rígida no rodapé:
%      1. Fonte   (obrigatória — seção 4.10)
%      2. Nota    (quando necessária — seção 4.11)
%      3. Notas específicas, em ordem de chamada (seção 4.12)
%
%    A implementação usa uma lista de tokens acumulada durante a declaração
%    da tabela e impressa ao final via \ibgeRodape.
% -----------------------------------------------------------------------------

% Variáveis internas de acumulação
\tl_new:N \l_ibge_fonte_tl
\tl_new:N \l_ibge_nota_tl
\seq_new:N \l_ibge_notas_esp_seq   % sequência ordenada de notas específicas

% Comando público: define a fonte obrigatória
\NewDocumentCommand{\ibgeFonte}{ m }{
  \tl_set:Nn \l_ibge_fonte_tl {#1}
}

% Comando público: define a nota geral
\NewDocumentCommand{\ibgeNota}{ m }{
  \tl_set:Nn \l_ibge_nota_tl {#1}
}

% Comando público: adiciona uma nota específica (chamada numérica — seção 4.9)
% O argumento #1 é o número da chamada; #2 é o texto da nota
\NewDocumentCommand{\ibgeNotaEsp}{ m m }{
  \seq_put_right:Nn \l_ibge_notas_esp_seq { (#1)~#2 }
}

% Comando que imprime o rodapé completo com a ordem exigida pela norma
\NewDocumentCommand{\ibgeRodape}{}{
  \par\vspace{4pt}\small
  % Fonte (obrigatória)
  \tl_if_empty:NF \l_ibge_fonte_tl {
    \noindent\textbf{Fonte:}~\tl_use:N \l_ibge_fonte_tl \par
  }
  % Nota geral
  \tl_if_empty:NF \l_ibge_nota_tl {
    \noindent\textbf{Nota:}~\tl_use:N \l_ibge_nota_tl \par
  }
  % Notas específicas em ordem de chamada (seção 4.12.2)
  \seq_map_inline:Nn \l_ibge_notas_esp_seq {
    \noindent ##1 \par
  }
  % Limpar estado após impressão
  \tl_clear:N \l_ibge_fonte_tl
  \tl_clear:N \l_ibge_nota_tl
  \seq_clear:N \l_ibge_notas_esp_seq
}

% Chamada remissiva inline (seção 4.9.1): entre parênteses, exponencial ou
% entre colchetes. O padrão adotado aqui é expoente entre parênteses.
\NewDocumentCommand{\ibgeChamada}{ m }{%
  \textsuperscript{(#1)}%
}

% -----------------------------------------------------------------------------
% 6. APRESENTAÇÃO DE TEMPO (seção 5)
%    Série consecutiva  → pontos ligados por hífen      ex.: 1981-1985
%    Série não consecutiva → pontos ligados por barra   ex.: 1981/1985
%    Safra              → dois últimos dígitos com barra ex.: Safra 91/92
% -----------------------------------------------------------------------------

\NewDocumentCommand{\ibgeSerieConsec}{ m m }{ #1\textendash#2 }
\NewDocumentCommand{\ibgeSerieNConsec}{ m m }{ #1/#2 }
\NewDocumentCommand{\ibgeSafra}{ m m }{
  Safra~\ibge_safra_digitos:n{#1}\slash\ibge_safra_digitos:n{#2}
}

% Extrai os dois últimos dígitos de um ano de quatro dígitos
\cs_new:Npn \ibge_safra_digitos:n #1 {
  % #1 é ex. "1991" — pega os dois últimos caracteres
  \str_range:nnn {#1} {3} {4}
}

% -----------------------------------------------------------------------------
% 7. APRESENTAÇÃO DE CLASSES DE FREQUÊNCIA (seção 6)
%    6.1 — inclui extremo inferior, exclui superior: "w a menos de z"
%    6.2 — exclui inferior, inclui superior: "mais de w a z"
%    6.3 — inclui ambos: "w a z"
%    A norma também aceita notações gráficas com colchetes/barras (6.1b, 6.2b, 6.3b)
%    mas a representação textual é mais portátil.
% -----------------------------------------------------------------------------

% w ⊢ z  (inclui w, exclui z)
\NewDocumentCommand{\ibgeClasseIE}{ m m }{ #1~a~menos~de~#2 }

% w ⊣ z  (exclui w, inclui z)
\NewDocumentCommand{\ibgeClasseEI}{ m m }{ mais~de~#1~a~#2 }

% w ⊢⊣ z (inclui ambos)
\NewDocumentCommand{\ibgeClasseII}{ m m }{ #1~a~#2 }

% -----------------------------------------------------------------------------
% 8. TÍTULO (seção 4.2)
%    A norma exige: natureza + abrangência geográfica + abrangência temporal
%    A implementação constrói o título a partir de partes semânticas,
%    formatando automaticamente com " — " como separador (padrão IBGE).
%
%    Uso:
%      \ibgeTitulo{Produção de casulos do bicho-da-seda}
%                 {por Unidade da Federação — Brasil}
%                 {1974}
% -----------------------------------------------------------------------------

\NewDocumentCommand{\ibgeTitulo}{ m m m }{
  \begin{center}
    \normalsize #1,~#2~\textendash~#3
  \end{center}
}

% -----------------------------------------------------------------------------
% 9. ARREDONDAMENTO (seção 7)
%    A norma define um procedimento específico para o caso em que a soma
%    das parcelas arredondadas diverge do total arredondado (seção 7.4b):
%    corrigir a parcela com menor |razão de arredondamento|.
%
%    Esta lógica NÃO pode ser implementada em LaTeX puro de forma genérica
%    (requer acesso aos dados brutos). A solução arquitetural aqui é:
%    a) fornecer o comando \ibgeNotaArrend{} para declarar a nota padrão
%       "Os dados numéricos foram arredondados" (seção 7, cabeçalho)
%    b) deixar a responsabilidade do cálculo 7.4b para o fluxo de dados
%       upstream (Python, R, etc.) que alimenta a tabela
% -----------------------------------------------------------------------------

\NewDocumentCommand{\ibgeNotaArrend}{}{%
  Dados numéricos arredondados.
  As divergências entre a soma das parcelas e os totais são provenientes
  do critério de arredondamento.
}

% -----------------------------------------------------------------------------
% 10. EXEMPLO DE USO (comentado)
% -----------------------------------------------------------------------------
%
% \ibgeFonte{Fundação Instituto Brasileiro de Geografia e Estatística – IBGE.}
% \ibgeNota{Dados sujeitos a retificação.}
% \ibgeNotaEsp{1}{Inclui registros de nascidos vivos em anos anteriores.}
%
% \ibgeTitulo
%   {Produção de casulos do bicho-da-seda}
%   {por Unidade da Federação — Brasil}
%   {1974}
%
% \begin{tabelaibge}{
%   colspec = {l S[table-format=3.2] S[table-format=3.2]},
% }
%   \hline[0.8pt]
%   {Unidade da Federação} & {Produção (t)} & {Relativa (\%)} \\
%   \hline[0.4pt]
%   São Paulo              & 120,50         & 45,30           \\
%   Paraná                 & 98,20          & 36,90           \\
%   \hline[0.8pt]
% \end{tabelaibge}
%
% \ibgeRodape
%
